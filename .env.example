# PagerMon Ingest Core configuration
#
# Prefixes:
# - Core:    INGEST_CORE__*
# - Adapter: INGEST_ADAPTER__*

# Core runtime settings
INGEST_CORE__LABEL=pagermon-ingest

# Required API target configuration
# Target 1 via alias variables
INGEST_CORE__API_NAME=pm-prod-a
INGEST_CORE__API_URL=http://pagermon:3000
INGEST_CORE__API_KEY=your_api_key_here
# For Docker secrets, prefer *_FILE over plain key:
# INGEST_CORE__API_KEY_FILE=/run/secrets/pagermon_api_key
# Do not set KEY and KEY_FILE for the same target at the same time.

# Additional targets via enumerated variables
# You can use INGEST_CORE__API_1_... for the first target if you prefer to do so.
# You cannot define INGEST_CORE_API_... and API_1_... at the same time, since both represent the first target.
# Start extra targets at INGEST_CORE__API_2_* when API_URL/API_NAME/API_KEY are used.
# INGEST_CORE__API_2_NAME=pm-prod-b
# INGEST_CORE__API_2_URL=http://pagermon-b:3000
# INGEST_CORE__API_2_KEY=key_b
# INGEST_CORE__API_3_NAME=pm-prod-c
# INGEST_CORE__API_3_URL=http://pagermon-c:3000
# INGEST_CORE__API_3_KEY_FILE=/run/secrets/pagermon_api3_key

INGEST_CORE__REDIS_URL=redis://redis:6379
INGEST_CORE__ENABLE_DLQ=true
INGEST_CORE__HEALTH_CHECK_INTERVAL=10000
INGEST_CORE__HEALTH_UNHEALTHY_THRESHOLD=3

# Adapter settings are forwarded to the selected adapter entry.
# Example keys (actual keys depend on the adapter implementation):
# INGEST_ADAPTER__FREQUENCIES=163000000
# INGEST_ADAPTER__PROTOCOLS=POCSAG512
# INGEST_ADAPTER__SMTP__HOST=smtp.example.org
